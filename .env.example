APP_NAME=OmniAgent Flow
APP_ENV=development
WEBHOOK_VERIFY_TOKEN=change-me
CORS_ORIGINS=["*"]
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
SESSION_TTL_SECONDS=1800
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=omniagent_knowledge
RAG_EMBEDDING_SIZE=384
RAG_DENSE_WEIGHT=0.65
RAG_BM25_WEIGHT=0.35
RAG_CANDIDATE_LIMIT=20
RAG_BM25_CORPUS_LIMIT=500
RAG_ENABLE_RERANKER=false
RAG_RERANKER_MODEL=BAAI/bge-reranker-base
HUBSPOT_SYNC_ENABLED=false
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_BASE_URL=https://api.hubapi.com
HUBSPOT_TIMEOUT_SECONDS=10
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SECONDS=10
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
